{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "jsx": "react-jsx",
    "types": ["node", "mocha", "vscode"],
    "paths": {
      "@molvis/core": ["../core/src/index.ts"],
      "@molvis/core/io": ["../core/src/io/index.ts"],
      "@molvis/core/io/formats": ["../core/src/io/formats.ts"],
      "@molcrafts/molplot": ["../molplot/src/index.ts"],
      "@/*": ["../page/src/*"]
    }
  },
  "include": ["src/**/*", "../core/src/types/**/*", "../page/src/**/*.d.ts"],
  "exclude": ["rslib.*.config.ts"]
}
