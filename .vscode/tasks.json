{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "label": "vsc-ext: build",
      "script": "build",
      "options": {
        "cwd": "${workspaceFolder}/vsc-ext"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "label": "vsc-ext: watch",
      "script": "watch",
      "options": {
        "cwd": "${workspaceFolder}/vsc-ext"
      },
      "group": "build",
      "presentation": {
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "type": "npm",
      "label": "vsc-ext: test",
      "script": "test",
      "options": {
        "cwd": "${workspaceFolder}/vsc-ext"
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
