{
  "name": "@molcrafts/molvis-core",
  "version": "0.0.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./io": {
      "types": "./dist/io/index.d.ts",
      "import": "./dist/io/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": ["./dist/commands/*.js"],
  "scripts": {
    "build": "rslib build",
    "build:demo": "rsbuild build",
    "dev": "rsbuild dev",
    "preview:demo": "rsbuild preview",
    "typecheck": "tsc --noEmit",
    "test": "rstest run",
    "test:watch": "rstest watch",
    "release:check": "npm run build && npm run test && npm_config_cache=/tmp/npm-cache npm pack --dry-run"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.0",
    "@rslib/core": "^0.18.0",
    "@rstest/browser": "^0.9.4",
    "@rstest/core": "^0.9.4",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@babylonjs/core": "^7.52.2",
    "@babylonjs/gui": "^7.52.2",
    "@babylonjs/inspector": "^7.52.2",
    "@babylonjs/materials": "^7.52.2",
    "@molcrafts/molrs": "file:../vendor/molrs",
    "tslog": "^4.9.3"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "author": "Roy Kid",
  "license": "BSD-3-Clause",
  "description": "Molvis: interactive molecular visualization library"
}
