{
  "name": "molvis",
  "version": "0.0.2",
  "description": "interactive molecule visulization package",
  "author": "Roy Kid",
  "license": "BSD-3-Clause",
  "workspaces": ["core", "python", "page", "vsc-ext"],
  "scripts": {
    "dev:python": "npm run dev -w python",
    "dev:page": "npm run dev -w page",
    "dev:core": "npm run dev -w core",
    "build:core": "npm run build -w core",
    "build:python": "npm run build -w python",
    "build:page": "npm run build -w page",
    "build:vsc-ext": "npm run build -w vsc-ext",
    "build:all": "npm run build:core && npm run build:python && npm run build:page && npm run build:vsc-ext",
    "test:core": "npm run test -w core",
    "test:page": "npm run test -w page",
    "test:python": "npm run test -w python",
    "test:vsc-ext": "npm run test:unit -w vsc-ext",
    "test": "npm run test:core && npm run test:page && npm run test:python && npm run test:vsc-ext",
    "test:watch": "npm run test:watch -w core",
    "release:core:check": "npm run release:check -w core",
    "lint": "npx biome check --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "npx biome check --write --unsafe --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@rsbuild/core": "^1.2.19",
    "@rslib/core": "^0.5.4",
    "concurrently": "^9.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wait-on": "^9.0.3"
  }
}
