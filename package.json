{
  "name": "molvis",
  "version": "0.0.4",
  "description": "interactive molecule visulization package",
  "author": "Roy Kid",
  "license": "BSD-3-Clause",
  "workspaces": ["core", "page", "vsc-ext"],
  "scripts": {
    "dev:core": "npm run dev -w core",
    "dev:page": "npm run dev -w page",
    "build:core": "npm run build -w core",
    "build:page": "npm run build -w page && rm -rf python/src/molvis/dist && mkdir -p python/src/molvis/dist && cp -r page/dist/. python/src/molvis/dist/",
    "build:vsc-ext": "npm run build -w vsc-ext",
    "build:all": "npm run build:core && npm run build:page && npm run build:vsc-ext",
    "build:python": "npm run build:page",
    "build:standalone": "npm run build:page",
    "typecheck:core": "npm run typecheck -w core",
    "typecheck:page": "npm run typecheck -w page",
    "typecheck:vsc-ext": "npm run typecheck -w vsc-ext",
    "typecheck": "npm run typecheck:core && npm run typecheck:page && npm run typecheck:vsc-ext",
    "test:core": "npm run test -w core",
    "test:page": "npm run test -w page",
    "test:python": "cd python && python3 -m pytest tests",
    "test:vsc-ext": "npm run test:unit -w vsc-ext",
    "test": "npm run test:core && npm run test:page && npm run test:python && npm run test:vsc-ext",
    "test:watch": "npm run test:watch -w core",
    "release:core:check": "npm run release:check -w core",
    "lint": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@rsbuild/core": "^1.7.0",
    "@rslib/core": "^0.18.0",
    "concurrently": "^9.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@molcrafts/molrs": "^0.0.12"
  },
  "overrides": {
    "@rspack/core": "^1.6.0",
    "@rsbuild/core": "^1.7.0",
    "@rslib/core": "^0.18.0",
    "@rsbuild/plugin-react": "^1.4.0",
    "@rstest/core": "^0.9.0",
    "@rstest/browser": "^0.9.0"
  }
}
